        {
          "name": "GET All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"userId\", json[0].id);\r",
                  "\r",
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time < 1000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is array\", () => {\r",
                  "    pm.expect(json).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"First user has email\", () => {\r",
                  "    pm.expect(json[0]).to.have.property(\"email\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type is JSON\", () => {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
